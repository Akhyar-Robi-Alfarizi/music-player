                },
                {
                  "key": "description",
                  "value": "Deskripsi album",
                  "type": "text"
                },
                {
                  "key": "cover",
                  "type": "file",
                  "src": ""
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/albums",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "albums"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const data = pm.response.json();",
                  "pm.test('Response memiliki album baru', function () {",
                  "  pm.expect(data.album).to.be.an('object');",
                  "  pm.expect(data.album.id).to.exist;",
                  "});",
                  "",
                  "if (data.album && data.album.id) {",
                  "  pm.environment.set('albumId', String(data.album.id));",
                  "}"
                ]
              }
            }
          ],
          "response": []
        }
