    {
      "key": "registerName",
      "value": "Budi Santoso"
    },
    {
      "key": "registerUsername",
      "value": "budi"
    },
    {
      "key": "registerEmail",
      "value": "budi@mail.com"
    },
    {
      "key": "registerPassword",
      "value": "secret123"
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const requestName = pm.info.requestName || '';",
          "if (requestName === 'POST Register') {",
          "  const userSuffix = Date.now().toString().slice(-6);",
          "  pm.environment.set('registerName', `Budi ${userSuffix}`);",
          "  pm.environment.set('registerUsername', `budi${userSuffix}`);",
          "  pm.environment.set('registerEmail', `budi${userSuffix}@mail.com`);",
          "  pm.environment.set('registerPassword', 'secret123');",
          "}",
          "",
          "const randomSuffix = Date.now().toString().slice(-6);",
          "pm.environment.set('albumName', `Album-${randomSuffix}`);",
          "pm.environment.set('songTitle', `Song-${randomSuffix}`);"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{registerName}}\",\n  \"username\": \"{{registerUsername}}\",\n  \"email\": \"{{registerEmail}}\",\n  \"password\": \"{{registerPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            }
          },
          "response": []
        },
        {
          "name": "POST Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"{{registerUsername}}\",\n  \"password\": \"{{registerPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const data = pm.response.json();",
                  "",
                  "pm.test('Token tersedia di response', function () {",
                  "  pm.expect(data.token).to.be.a('string').and.not.empty;",
                  "});",
                  "",
                  "if (data.token) {",
                  "  pm.environment.set('token', data.token);",
                  "}"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "GET Me (Auth)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "me"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const data = pm.response.json();",
                  "pm.test('Response memiliki user', function () {",
                  "  pm.expect(data.user).to.be.an('object');",
                  "  pm.expect(data.user.id).to.exist;",
                  "});"
                ]
              }
            }
          ],
          "response": []
        }
      ]
    },
